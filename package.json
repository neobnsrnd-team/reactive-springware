{
  "name": "@neobnsrnd-team/reactive-springware",
  "version": "0.3.6",
  "type": "module",
  "description": "Figma 디자인 → React 컴포넌트 라이브러리 (Bank App 기반)",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json",
    "./dist/index.css": "./dist/index.css",
    "./design-tokens": "./design-tokens/globals.css"
  },
  "bin": {
    "rs-init": "./scripts/init.mjs",
    "rs-cleanup": "./scripts/cleanup.mjs"
  },
  "files": [
    "dist",
    "lib",
    "packages/component-library",
    ".storybook",
    "docs",
    "rules",
    "scripts/init.mjs",
    "scripts/cleanup.mjs",
    "design-tokens",
    "demo/react-demo-app/src/index.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.js",
    "prepack": "npm run build",
    "build:manifest": "node scripts/build-manifest.mjs",
    "extract:manifest": "tsx scripts/extract-manifest.ts",
    "build:all": "npm run build && npm run build:manifest && npm run extract:manifest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "release": "npm run build && npm publish"
  },
  "dependencies": {
    "@storybook/react-vite": "^10.3.3",
    "@tailwindcss/vite": "^4.2.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "storybook": "^10.3.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@tokens-studio/sd-transforms": "^2.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "sd-tailwindcss-transformer": "^2.2.1",
    "style-dictionary": "^5.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.3",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
